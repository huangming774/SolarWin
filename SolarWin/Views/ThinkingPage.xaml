<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.ThinkingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="寻思" />
                <TextBlock
                    Opacity="0.7"
                    Text="{x:Bind ViewModel.ConversationTitle, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Opacity="0.6"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Top">
                <Button Command="{x:Bind ViewModel.NewConversationCommand}" Content="新对话" />
                <Button Command="{x:Bind ViewModel.LoadHistoryCommand}" Content="历史" />
                <Button Command="{x:Bind ViewModel.LoadCommand}" Content="刷新" />
                <ProgressRing
                    Width="28"
                    Height="28"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Bot + Model selectors -->
        <Border
            Grid.Row="1"
            Padding="14"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE99A;" />
                        <TextBlock FontWeight="SemiBold" Text="机器人" />
                    </StackPanel>
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.AgentNames, Mode=OneWay}"
                        PlaceholderText="选择机器人…"
                        SelectedIndex="{x:Bind ViewModel.SelectedAgentIndex, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE950;" />
                        <TextBlock FontWeight="SemiBold" Text="模型" />
                    </StackPanel>
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.ModelNames, Mode=OneWay}"
                        PlaceholderText="选择模型…"
                        SelectedIndex="{x:Bind ViewModel.SelectedModelIndex, Mode=TwoWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages -->
        <Border
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <Grid>
                <ListView
                    x:Name="MessageList"
                    Padding="12"
                    ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ThoughtBubbleItem">
                            <Grid Margin="0,6" HorizontalAlignment="{x:Bind Alignment}">
                                <Border
                                    MaxWidth="560"
                                    Padding="12,10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Opacity="0.75"
                                                Text="{x:Bind RoleLabel}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.5"
                                                Text="{x:Bind TimeText}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.45"
                                                Text="{x:Bind ModelHint}" />
                                        </StackPanel>
                                        <TextBlock
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind Content}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Composer -->
        <Grid
            Grid.Row="3"
            ColumnSpacing="10"
            Padding="4,0,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="DraftBox"
                AcceptsReturn="True"
                MinHeight="44"
                MaxHeight="120"
                PlaceholderText="输入你的想法… 点发送或 Ctrl+Enter"
                Text="{x:Bind ViewModel.Draft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                KeyDown="DraftBox_OnKeyDown" />
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="6">
                <ProgressRing
                    Width="22"
                    Height="22"
                    HorizontalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsSending, Mode=OneWay}" />
                <Button
                    MinWidth="88"
                    Command="{x:Bind ViewModel.SendCommand}"
                    Content="发送"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
