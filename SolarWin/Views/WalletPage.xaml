<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.WalletPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="钱包" />

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock Opacity="0.65" Text="余额" />
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="{x:Bind ViewModel.BalanceText, Mode=OneWay}" />
                    <TextBlock Opacity="0.75" Text="{x:Bind ViewModel.WalletMetaText, Mode=OneWay}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock Opacity="0.65" Text="资产汇总" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.PocketSummaryText, Mode=OneWay}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <Button Command="{x:Bind ViewModel.LoadCommand}" Content="刷新" />
            <ProgressRing Width="28" Height="28" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <TextBlock VerticalAlignment="Center" Opacity="0.75" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <ListView ItemsSource="{x:Bind ViewModel.Transactions, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:WalletTransactionItemViewModel">
                        <Grid Padding="8,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                FontSize="18"
                                Glyph="&#xE8D4;"
                                VerticalAlignment="Top" />

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" TextWrapping="Wrap" />
                                <TextBlock Opacity="0.65" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind StatusText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind AmountText}" />
                                <TextBlock Opacity="0.65" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind TimeText}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <StackPanel
                        Padding="12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.LoadMoreVisibility, Mode=OneWay}">
                        <Button Command="{x:Bind ViewModel.LoadMoreCommand}" Content="加载更多" />
                        <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
                    </StackPanel>
                </ListView.Footer>
            </ListView>

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.65"
                Text="暂无交易"
                Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
