<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.ChatDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Click="BackButton_OnClick" Content="返回" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="{x:Bind ViewModel.RoomTitle, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <ProgressRing
                Grid.Column="2"
                Width="24"
                Height="24"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </Grid>

        <ListView
            x:Name="MessageList"
            Grid.Row="1"
            Padding="12,4"
            ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:MessageItemViewModel">
                    <Grid Margin="0,6" ColumnSpacing="8" HorizontalAlignment="{x:Bind Alignment}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Grid
                            Width="36"
                            Height="36"
                            VerticalAlignment="Top"
                            Opacity="{x:Bind SenderNameOpacity}">
                            <Border
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="18"
                                Opacity="{x:Bind InitialsOpacity, Mode=OneWay}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Initials}" />
                            </Border>
                            <Ellipse Opacity="{x:Bind AvatarOpacity, Mode=OneWay}">
                                <Ellipse.Fill>
                                    <ImageBrush
                                        ImageSource="{x:Bind AvatarImage, Mode=OneWay}"
                                        Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <Border
                            Grid.Column="1"
                            MaxWidth="420"
                            Padding="10,8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Opacity="{x:Bind BubbleOpacity}">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    Opacity="{x:Bind SenderNameOpacity}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind SenderName}" />

                                <!-- Text -->
                                <TextBlock
                                    Opacity="{x:Bind TextOpacity}"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind Content}"
                                    TextWrapping="WrapWholeWords" />

                                <!-- Attachments / images (DysonFS) -->
                                <ItemsControl
                                    ItemsSource="{x:Bind Attachments}"
                                    Opacity="{x:Bind AttachmentsOpacity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MessageAttachmentViewModel">
                                            <StackPanel Margin="0,2" Spacing="4">
                                                <Grid MaxWidth="280" Opacity="{x:Bind ImageAreaOpacity}">
                                                    <Border
                                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                        CornerRadius="8"
                                                        MinHeight="80">
                                                        <Grid>
                                                            <ProgressRing
                                                                Width="28"
                                                                Height="28"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                IsActive="{x:Bind IsLoading, Mode=OneWay}" />
                                                            <Image
                                                                MaxHeight="240"
                                                                Stretch="Uniform"
                                                                Opacity="{x:Bind ImageOpacity, Mode=OneWay}"
                                                                Source="{x:Bind Image, Mode=OneWay}"
                                                                Tapped="AttachmentImage_OnTapped"
                                                                Tag="{x:Bind}" />
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <Border
                                                    Padding="8,4"
                                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="6"
                                                    Opacity="{x:Bind FileChipOpacity}">
                                                    <TextBlock
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{x:Bind Name}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Opacity="0.55"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind TimeText}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Padding="12,0" Spacing="4">
            <ProgressRing
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                TextWrapping="Wrap" />
            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                Opacity="{x:Bind ViewModel.PendingImagePanelOpacity, Mode=OneWay}">
                <FontIcon Glyph="&#xEB9F;" />
                <TextBlock
                    VerticalAlignment="Center"
                    Opacity="0.85"
                    Text="{x:Bind ViewModel.PendingImageName, Mode=OneWay}" />
                <Button
                    Command="{x:Bind ViewModel.ClearPendingImageCommand}"
                    Content="清除" />
            </StackPanel>
            <ProgressBar
                Maximum="1"
                Minimum="0"
                Value="{x:Bind ViewModel.UploadProgress, Mode=OneWay}" />
        </StackPanel>

        <Grid
            Grid.Row="3"
            Padding="12"
            ColumnSpacing="8"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Click="PickImage_OnClick"
                Content="图片"
                IsEnabled="{x:Bind ViewModel.IsComposerEnabled, Mode=OneWay}" />
            <TextBox
                x:Name="DraftBox"
                Grid.Column="1"
                AcceptsReturn="False"
                IsEnabled="{x:Bind ViewModel.IsComposerEnabled, Mode=OneWay}"
                KeyDown="DraftBox_OnKeyDown"
                PlaceholderText="输入消息…"
                Text="{x:Bind ViewModel.Draft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="2"
                MinWidth="88"
                Command="{x:Bind ViewModel.SendCommand}"
                Content="发送"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Page>
