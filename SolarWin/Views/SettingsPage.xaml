<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="520" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Click="Back_OnClick" Content="返回" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="设置" />
            </StackPanel>

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="关于" />
            <TextBlock Text="Solar Network Windows 客户端（SolarWin）" />
            <TextBlock>
                <Run Text="版本 " />
                <Run Text="{x:Bind ViewModel.VersionText, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Opacity="0.7" Text="API：https://api.solian.app" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="外观" />
            <TextBlock Text="{x:Bind ViewModel.ThemeLabel, Mode=OneWay}" />
            <ComboBox
                Width="220"
                Header="主题"
                SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                <ComboBoxItem Content="跟随系统" />
                <ComboBoxItem Content="浅色" />
                <ComboBoxItem Content="深色" />
            </ComboBox>
            <Button Command="{x:Bind ViewModel.ApplyThemeCommand}" Content="应用主题" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="账户" />
            <Button
                Command="{x:Bind ViewModel.LogoutCommand}"
                Content="退出登录"
                Style="{StaticResource AccentButtonStyle}" />

            <TextBlock
                Opacity="0.8"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
