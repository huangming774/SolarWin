<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.PostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SolarWin.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="帖子" />
            <Button
                VerticalAlignment="Center"
                Command="{x:Bind ViewModel.LoadCommand}"
                Content="刷新" />
            <TextBlock
                VerticalAlignment="Center"
                Opacity="0.75"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <ProgressRing
                Width="28"
                Height="28"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <TextBlock
                VerticalAlignment="Center"
                Opacity="0.7"
                Text="信息流" />
            <ComboBox
                MinWidth="140"
                SelectedIndex="{x:Bind ViewModel.FeedModeIndex, Mode=TwoWay}">
                <ComboBoxItem Content="时间线" />
                <ComboBoxItem Content="公共帖子" />
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                MaxHeight="140"
                MinHeight="44"
                AcceptsReturn="True"
                PlaceholderText="分享此刻的想法…"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                Text="{x:Bind ViewModel.NewPostContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />
            <Button
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Command="{x:Bind ViewModel.CreatePostCommand}"
                Content="发布"
                IsEnabled="{x:Bind ViewModel.CanPost, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <Grid Grid.Row="3">
            <ListView
                IsItemClickEnabled="True"
                ItemClick="PostList_OnItemClick"
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PostItemViewModel">
                        <Border
                            Padding="8,12"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <PersonPicture
                                    Width="40"
                                    Height="40"
                                    Initials="{x:Bind Initials}"
                                    ProfilePicture="{x:Bind AvatarImage, Mode=OneWay}" />

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind AuthorName}" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            Opacity="0.55"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind AuthorHandle}" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            Opacity="0.55"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind TimeText}" />
                                    </StackPanel>

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind TitleVisibility}" />

                                    <TextBlock Text="{x:Bind ContentText}" TextWrapping="Wrap" />

                                    <Border
                                        Padding="8"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{x:Bind ForwardedVisibility}">
                                        <TextBlock
                                            Opacity="0.8"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind ForwardedText}"
                                            TextWrapping="Wrap" />
                                    </Border>

                                    <Grid HorizontalAlignment="Left" Visibility="{x:Bind ImagesVisibility}">
                                        <Image
                                            MaxWidth="480"
                                            MaxHeight="320"
                                            HorizontalAlignment="Left"
                                            Source="{x:Bind FirstImage, Mode=OneWay}"
                                            Stretch="Uniform" />
                                        <Border
                                            Margin="0,0,8,8"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Visibility="{x:Bind ExtraImagesVisibility}">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind ExtraImagesText}" />
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        Opacity="0.55"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind StatsText, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <StackPanel
                        Padding="12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.LoadMoreVisibility, Mode=OneWay}">
                        <Button
                            Command="{x:Bind ViewModel.LoadMoreCommand}"
                            Content="加载更多" />
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
                    </StackPanel>
                </ListView.Footer>
            </ListView>

            <controls:PageStateOverlay
                EmptyMessage="还没有帖子,来发第一条吧"
                ErrorMessage="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                HasError="{x:Bind ViewModel.HasError, Mode=OneWay}"
                IsEmpty="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                IsLoading="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                LoadingMessage="正在加载帖子…" />
        </Grid>
    </Grid>
</Page>
