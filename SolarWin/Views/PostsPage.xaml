<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.PostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SolarWin.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="帖子" />
            <Button
                VerticalAlignment="Center"
                Command="{x:Bind ViewModel.LoadCommand}"
                Content="刷新" />
            <TextBlock
                VerticalAlignment="Center"
                Opacity="0.75"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <ProgressRing
                Width="28"
                Height="28"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <TextBlock
                VerticalAlignment="Center"
                Opacity="0.7"
                Text="信息流" />
            <ComboBox
                MinWidth="140"
                SelectedIndex="{x:Bind ViewModel.FeedModeIndex, Mode=TwoWay}">
                <ComboBoxItem Content="时间线" />
                <ComboBoxItem Content="公共帖子" />
            </ComboBox>
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Spacing="8">
                <TextBox
                    MaxHeight="140"
                    MinHeight="44"
                    AcceptsReturn="True"
                    IsEnabled="{x:Bind ViewModel.IsComposerEnabled, Mode=OneWay}"
                    PlaceholderText="分享此刻的想法… 可添加照片"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{x:Bind ViewModel.NewPostContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />

                <!-- Pending photos -->
                <ItemsControl ItemsSource="{x:Bind ViewModel.PendingAttachments, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PendingPostAttachment">
                            <Border
                                Width="96"
                                Height="96"
                                Margin="0,0,8,0"
                                CornerRadius="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Grid>
                                    <Image
                                        Stretch="UniformToFill"
                                        Source="{x:Bind Preview}" />
                                    <Border
                                        VerticalAlignment="Bottom"
                                        Background="#99000000"
                                        Padding="4,2">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="White"
                                            Text="{x:Bind FileName}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="4"
                                        Padding="6,2"
                                        Background="#CC000000"
                                        Foreground="White"
                                        Content="×"
                                        Tag="{x:Bind}"
                                        Click="RemovePending_OnClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ProgressBar
                    Maximum="1"
                    Minimum="0"
                    Value="{x:Bind ViewModel.UploadProgress, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.UploadProgressVisibility, Mode=OneWay}" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Click="PickImage_OnClick"
                        Content="添加照片"
                        IsEnabled="{x:Bind ViewModel.IsComposerEnabled, Mode=OneWay}"
                        ToolTipService.ToolTip="从本地选择图片并上传" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Opacity="0.55"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="支持 jpg / png / gif / webp，可多张" />
                    <Button
                        Grid.Column="2"
                        Command="{x:Bind ViewModel.ClearPendingAttachmentsCommand}"
                        Content="清空图片"
                        Visibility="{x:Bind ViewModel.PendingAttachmentsVisibility, Mode=OneWay}" />
                    <Button
                        Grid.Column="3"
                        MinWidth="88"
                        Command="{x:Bind ViewModel.CreatePostCommand}"
                        Content="发布"
                        IsEnabled="{x:Bind ViewModel.CanPost, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <ListView
                IsItemClickEnabled="True"
                ItemClick="PostList_OnItemClick"
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PostItemViewModel">
                        <Border
                            Padding="8,12"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="AuthorAvatar_OnClick"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="查看主页">
                                    <PersonPicture
                                        Width="40"
                                        Height="40"
                                        Initials="{x:Bind Initials}"
                                        ProfilePicture="{x:Bind AvatarImage, Mode=OneWay}" />
                                </Button>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <HyperlinkButton
                                            Padding="0"
                                            Click="AuthorName_OnClick"
                                            Content="{x:Bind AuthorName}"
                                            FontWeight="SemiBold"
                                            Tag="{x:Bind}"
                                            ToolTipService.ToolTip="查看主页" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            Opacity="0.55"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind AuthorHandle}" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            Opacity="0.55"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind TimeText}" />
                                    </StackPanel>

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind TitleVisibility}" />

                                    <TextBlock Text="{x:Bind ContentText}" TextWrapping="Wrap" />

                                    <Border
                                        Padding="8"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{x:Bind ForwardedVisibility}">
                                        <TextBlock
                                            Opacity="0.8"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind ForwardedText}"
                                            TextWrapping="Wrap" />
                                    </Border>

                                    <Grid HorizontalAlignment="Left" Visibility="{x:Bind ImagesVisibility}">
                                        <Image
                                            MaxWidth="480"
                                            MaxHeight="320"
                                            HorizontalAlignment="Left"
                                            Source="{x:Bind FirstImage, Mode=OneWay}"
                                            Stretch="Uniform" />
                                        <Border
                                            Margin="0,0,8,8"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Visibility="{x:Bind ExtraImagesVisibility}">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind ExtraImagesText}" />
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        Opacity="0.55"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind StatsText, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <StackPanel
                        Padding="12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.LoadMoreVisibility, Mode=OneWay}">
                        <Button
                            Command="{x:Bind ViewModel.LoadMoreCommand}"
                            Content="加载更多" />
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
                    </StackPanel>
                </ListView.Footer>
            </ListView>

            <controls:PageStateOverlay
                EmptyMessage="还没有帖子,来发第一条吧"
                ErrorMessage="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                HasError="{x:Bind ViewModel.HasError, Mode=OneWay}"
                IsEmpty="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                IsLoading="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                LoadingMessage="正在加载帖子…" />
        </Grid>
    </Grid>
</Page>
