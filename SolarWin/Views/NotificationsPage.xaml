<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SolarWin.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="通知中心" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <Button Command="{x:Bind ViewModel.LoadCommand}" Content="刷新" />
            <Button
                Command="{x:Bind ViewModel.MarkAllReadCommand}"
                Content="全部已读"
                Style="{StaticResource AccentButtonStyle}" />
            <TextBlock
                VerticalAlignment="Center"
                Opacity="0.75"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <ProgressRing
                Width="28"
                Height="28"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <ListView
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationItemViewModel">
                        <Grid Padding="8,10" ColumnSpacing="12" Opacity="{x:Bind CardOpacity}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Ellipse
                                Width="10"
                                Height="10"
                                VerticalAlignment="Top"
                                Margin="0,6,0,0"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                Opacity="{x:Bind UnreadOpacity}" />

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Opacity="{x:Bind CardOpacity}"
                                    Text="{x:Bind Title}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.8"
                                    Text="{x:Bind Content}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Opacity="0.55"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind Topic}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                <TextBlock
                                    Opacity="0.6"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind TimeText}" />
                                <TextBlock
                                    Opacity="{x:Bind UnreadOpacity}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Text="{x:Bind UnreadLabel}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <controls:PageStateOverlay
                EmptyMessage="暂无通知"
                ErrorMessage="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                HasError="{x:Bind ViewModel.HasError, Mode=OneWay}"
                IsEmpty="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                IsLoading="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                LoadingMessage="正在加载通知…" />
        </Grid>
    </Grid>
</Page>
