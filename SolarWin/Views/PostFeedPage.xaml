<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.PostFeedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Click="BackButton_OnClick" Content="返回" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock Opacity="0.65" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}" />
            </StackPanel>
            <Button
                Grid.Column="2"
                VerticalAlignment="Center"
                Command="{x:Bind ViewModel.ToggleSubscribeCommand}"
                Content="{x:Bind ViewModel.SubscribeButtonText, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.CanSubscribe, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
            <ProgressRing
                Grid.Column="3"
                Width="24"
                Height="24"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </Grid>

        <StackPanel Grid.Row="1" Padding="16,0,16,8" Orientation="Horizontal" Spacing="12">
            <Button Command="{x:Bind ViewModel.LoadCommand}" Content="刷新" />
            <TextBlock VerticalAlignment="Center" Opacity="0.7" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2" Padding="16,0,16,16">
            <ListView
                IsItemClickEnabled="True"
                ItemClick="PostList_OnItemClick"
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PostItemViewModel">
                        <Border
                            Padding="10,12"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <HyperlinkButton
                                        Padding="0"
                                        Click="AuthorName_OnClick"
                                        Content="{x:Bind AuthorName}"
                                        FontWeight="SemiBold"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="查看主页" />
                                    <TextBlock Opacity="0.55" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind AuthorHandle}" />
                                    <TextBlock Opacity="0.55" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind TimeText}" />
                                </StackPanel>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Title}"
                                    TextWrapping="Wrap"
                                    Visibility="{x:Bind TitleVisibility}" />
                                <TextBlock Text="{x:Bind ContentText}" TextWrapping="WrapWholeWords" MaxLines="5" />
                                <TextBlock Opacity="0.55" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind StatsText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <StackPanel Padding="0,12" HorizontalAlignment="Center" Spacing="8">
                        <Button
                            Command="{x:Bind ViewModel.LoadMoreCommand}"
                            Content="加载更多"
                            Visibility="{x:Bind ViewModel.LoadMoreVisibility, Mode=OneWay}" />
                        <ProgressRing
                            Width="28"
                            Height="28"
                            IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.55"
                            Text="暂无帖子"
                            Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />
                    </StackPanel>
                </ListView.Footer>
            </ListView>
        </Grid>
    </Grid>
</Page>
