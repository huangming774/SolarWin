<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.RealmDetailPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SolarWin.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Click="BackButton_OnClick" Content="返回" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <ProgressRing
                Grid.Column="2"
                Width="24"
                Height="24"
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24">
            <StackPanel MaxWidth="720" Spacing="14">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Width="72" Height="72">
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" />
                        <Border CornerRadius="12">
                            <Border.Background>
                                <ImageBrush
                                    ImageSource="{x:Bind ViewModel.PictureImage, Mode=OneWay}"
                                    Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                        <TextBlock Opacity="0.75" Text="{x:Bind ViewModel.SlugText, Mode=OneWay}" />
                        <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.Meta, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.MembershipText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.JoinCommand}" Content="加入" Style="{StaticResource AccentButtonStyle}" />
                    <Button Command="{x:Bind ViewModel.LeaveCommand}" Content="退出" />
                    <Button Command="{x:Bind ViewModel.LoadCommand}" Content="刷新" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox
                        Width="280"
                        PlaceholderText="邀请用户 GUID"
                        Text="{x:Bind ViewModel.InviteUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{x:Bind ViewModel.InviteCommand}" Content="邀请成员" />
                </StackPanel>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="成员" />
                <ListView
                    MaxHeight="320"
                    ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SocialListItemViewModel">
                            <Grid Padding="4,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                    <TextBlock Opacity="0.75" Text="{x:Bind Subtitle}" />
                                    <TextBlock Opacity="0.55" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind Meta}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.OpenMemberProfileCommand}"
                                    CommandParameter="{x:Bind}"
                                    Content="资料" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="角色权限" />
                <ListView
                    MaxHeight="220"
                    ItemsSource="{x:Bind ViewModel.Permissions, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SocialListItemViewModel">
                            <StackPanel Padding="4,8" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <TextBlock Opacity="0.75" Text="{x:Bind Subtitle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
