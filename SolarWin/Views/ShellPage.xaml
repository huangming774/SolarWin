<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
      Nav icons are assigned in code-behind (ApplyNavIcons).
      Assets/icon.ico is the app/tray icon only — not per-menu glyphs.
    -->
    <Grid x:Name="ShellRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="ToastBar"
            Grid.Row="0"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational" />

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Auto"
            IsSettingsVisible="True"
            OpenPaneLength="240"
            CompactPaneLength="48"
            IsPaneToggleButtonVisible="True"
            BackRequested="NavView_OnBackRequested"
            Loaded="NavView_OnLoaded"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="首页" Tag="home" />
                <NavigationViewItem Content="聊天" Tag="chat" />
                <NavigationViewItem Content="帖子" Tag="posts" />
                <NavigationViewItem Content="探索" Tag="explore" />
                <NavigationViewItem Content="寻思" Tag="thinking" />
                <NavigationViewItem Content="天气" Tag="weather" />
                <NavigationViewItem Content="文件" Tag="files" />
                <NavigationViewItem x:Name="NotificationsNavItem" Content="通知" Tag="notifications">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge
                            x:Name="NotificationInfoBadge"
                            Opacity="{x:Bind ViewModel.NotificationBadgeOpacity, Mode=OneWay}"
                            Value="{x:Bind ViewModel.UnreadNotificationCount, Mode=OneWay}" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem Content="钱包" Tag="wallet" />
                <NavigationViewItem Content="我的" Tag="profile" />
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Padding="12" Spacing="4">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.UserDisplayName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Opacity="0.7"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.UserHandle, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.6"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Page>
