<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SolarWin.Views.PostDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media.Imaging"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Click="BackButton_OnClick" Content="返回" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="帖子详情" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="24">
                <StackPanel
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <PersonPicture
                            Width="48"
                            Height="48"
                            Initials="{x:Bind ViewModel.Initials, Mode=OneWay}"
                            ProfilePicture="{x:Bind ViewModel.AvatarImage, Mode=OneWay}" />
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.AuthorName, Mode=OneWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    Opacity="0.55"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.AuthorHandle, Mode=OneWay}" />
                                <TextBlock
                                    Opacity="0.55"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.TimeText, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind ViewModel.TitleVisibility, Mode=OneWay}" />

                    <TextBlock
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.ContentText, Mode=OneWay}"
                        TextWrapping="Wrap" />

                    <Border
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{x:Bind ViewModel.ForwardedVisibility, Mode=OneWay}">
                        <TextBlock
                            Opacity="0.8"
                            Text="{x:Bind ViewModel.ForwardedText, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </Border>

                    <ItemsControl
                        ItemsSource="{x:Bind ViewModel.Images, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.ImagesVisibility, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="media:BitmapImage">
                                <Image
                                    MaxWidth="560"
                                    MaxHeight="480"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Left"
                                    Source="{x:Bind}"
                                    Stretch="Uniform" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Opacity="0.55"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatsText, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
