<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SolarWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SolarWin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Solar Network"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootHost" ActualThemeChanged="RootHost_OnActualThemeChanged">
        <!-- Custom wallpaper (behind everything) -->
        <Image
            x:Name="WallpaperImage"
            Stretch="UniformToFill"
            Visibility="Collapsed" />
        <!-- Soft wash driven by blur slider -->
        <Border
            x:Name="WallpaperBlurWash"
            IsHitTestVisible="False"
            Visibility="Collapsed" />
        <!-- Glass / frosted acrylic overlay -->
        <Border
            x:Name="WallpaperEffectOverlay"
            IsHitTestVisible="False"
            Visibility="Collapsed" />

        <Grid x:Name="ChromeRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TitleBar x:Name="AppTitleBar" Title="Solar Network">
                <TitleBar.IconSource>
                    <ImageIconSource ImageSource="Assets/icon.ico" />
                </TitleBar.IconSource>
            </TitleBar>

            <!--
                The Frame hosts pages for your application content. Add your UI to
                MainPage.xaml rather than here so you can use Page features such as
                navigation events and the Loaded lifecycle.
            -->
            <Frame x:Name="RootFrame" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
